# --- Supabase (https://supabase.com) ---
# Project Settings → API

# Public — safe to expose in the browser bundle (must be real values or Auth shows "Failed to fetch")
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only — NEVER commit real values or expose to the client.
# Bypasses Row Level Security; use only in Server Actions / Route Handlers / Edge with validation.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Optional: direct Postgres (Database → Connection string) for CLI / BI / migrations outside Supabase UI
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Booking email (SMTP) — GoDaddy Workspace / similar ---
# Typical GoDaddy: SMTP_HOST=smtpout.secureserver.net  SMTP_PORT=465  SMTP_SECURE=true
# Or STARTTLS: SMTP_PORT=587  SMTP_SECURE=false
# SMTP_USER / SMTP_PASSWORD = mailbox credentials. EMAIL_FROM usually same as SMTP_USER.
# BOOKING_NOTIFY_EMAIL = inbox that receives "new booking" alerts.
# Optional operational FX overrides (app baseline when unset: ₦1385/USD, LD 190/USD)
# SALON_NGN_PER_USD=1385
# SALON_LRD_PER_USD=190
# NEXT_PUBLIC_SALON_NGN_PER_USD=1385
# NEXT_PUBLIC_SALON_LRD_PER_USD=190

SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=bookings@yourdomain.com
SMTP_PASSWORD=your_mailbox_password
EMAIL_FROM=bookings@yourdomain.com
BOOKING_NOTIFY_EMAIL=owner@yourdomain.com
# BOOKING_CUSTOMER_CONFIRMATION=true
